# ── Pulseboard Environment Configuration ──
# Copy to .env and adjust as needed
# Both docker-compose.yml and docker-compose.dev.yml read from this file

# ── Host Port Mapping ──
# Production uses 90xx, dev uses 91xx by default
# Change the base to avoid conflicts with other projects
POSTGRES_PORT=9001
REDIS_PORT=9002
NATS_PORT=9003
NATS_MONITOR_PORT=9004
API_PORT=9010
WEB_PORT=9020
DAGSTER_PORT=9030
MINIO_API_PORT=9040
MINIO_CONSOLE_PORT=9041

# ── Database ──
POSTGRES_DB=pulseboard
POSTGRES_USER=pulseboard
POSTGRES_PASSWORD=pulseboard_dev

# ── API Gateway ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── Object Storage ──
# Provider: minio (dev), s3, backblaze, azure, local
STORAGE_PROVIDER=minio
STORAGE_BUCKET=pulseboard
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── ETL Pipeline ���─
# Minimum seconds between auto-syncs per connector (default: 21600 = 6 hours)
SYNC_MIN_INTERVAL_SECONDS=21600

# ── Frontend ──
VITE_API_URL=http://localhost:9010/api

# ── Cloudflare Tunnel (optional, for remote access to dev) ──
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
